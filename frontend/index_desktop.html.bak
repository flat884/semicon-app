<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>SEMICON SCOPE</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700;800&family=Zen+Kaku+Gothic+New:wght@400;500;700;900&display=swap');
  :root{--bg:#0a0e14;--panel:#0f1620;--panel2:#131c28;--line:#1e2a3a;--txt:#d7e0ec;--dim:#6b7d93;
    --dimmer:#3f4f63;--up:#23d18b;--down:#ff5d6c;--warn:#ffb454;--accent:#46b1ff;--ipo:#c792ea;
    --mono:'JetBrains Mono',monospace;--jp:'Zen Kaku Gothic New',sans-serif;}
  *{box-sizing:border-box;margin:0;padding:0}
  body{background:var(--bg);color:var(--txt);font-family:var(--jp);font-size:13px;
    background-image:radial-gradient(circle at 20% -10%,rgba(70,177,255,.06),transparent 40%);min-height:100vh}
  ::-webkit-scrollbar{width:9px;height:9px}::-webkit-scrollbar-thumb{background:var(--line);border-radius:4px}
  .mono{font-family:var(--mono)}
  header{position:sticky;top:0;z-index:30;background:linear-gradient(180deg,#0c1119,#0a0e14);
    border-bottom:1px solid var(--line);padding:10px 18px;display:flex;align-items:center;gap:20px;flex-wrap:wrap}
  .brand{font-family:var(--mono);font-weight:800;font-size:18px;letter-spacing:1px;color:#fff}
  .brand b{color:var(--accent)} .brand small{display:block;font-size:9px;color:var(--dim);letter-spacing:3px;font-weight:500;margin-top:1px}
  .clock{margin-left:auto;display:flex;gap:18px;align-items:center;flex-wrap:wrap}
  .stat{font-family:var(--mono);font-size:11px;color:var(--dim);line-height:1.4}
  .stat b{display:block;color:var(--txt);font-size:14px;font-weight:700}
  .delaybadge{background:rgba(255,180,84,.12);border:1px solid rgba(255,180,84,.4);color:var(--warn);
    padding:5px 11px;border-radius:5px;font-family:var(--mono);font-size:11px;font-weight:700;display:flex;align-items:center;gap:7px}
  .pulse{width:7px;height:7px;border-radius:50%;background:var(--warn);animation:pulse 1.4s infinite}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.25}} .counter{color:var(--accent)}
  .conn{font-family:var(--mono);font-size:10px;padding:3px 8px;border-radius:4px}
  .conn.ok{color:var(--up);border:1px solid rgba(35,209,139,.3)} .conn.ng{color:var(--down);border:1px solid rgba(255,93,108,.3)}
  .controls{padding:12px 18px;display:flex;gap:10px;align-items:center;flex-wrap:wrap;border-bottom:1px solid var(--line);background:var(--panel)}
  .search{flex:1;min-width:200px;position:relative}
  .search input{width:100%;background:var(--bg);border:1px solid var(--line);color:var(--txt);padding:9px 12px 9px 32px;border-radius:6px;font-family:var(--mono);font-size:12px}
  .search input:focus{outline:none;border-color:var(--accent)} .search::before{content:'⌕';position:absolute;left:11px;top:7px;color:var(--dim);font-size:15px}
  .chips{display:flex;gap:6px;flex-wrap:wrap}
  .chip{background:var(--panel2);border:1px solid var(--line);color:var(--dim);padding:6px 11px;border-radius:20px;font-size:11px;cursor:pointer;font-weight:500;transition:.15s;white-space:nowrap}
  .chip:hover{border-color:var(--dimmer);color:var(--txt)} .chip.on{background:rgba(70,177,255,.15);border-color:var(--accent);color:var(--accent)}
  .alerts{padding:8px 18px;display:flex;gap:10px;align-items:center;overflow-x:auto;border-bottom:1px solid var(--line);background:var(--panel2);min-height:38px}
  .alerts .lbl{font-family:var(--mono);font-size:10px;color:var(--dim);letter-spacing:1px;flex-shrink:0}
  .alert{flex-shrink:0;padding:5px 10px;border-radius:5px;font-size:11px;font-family:var(--mono);font-weight:700}
  .alert.surge{background:rgba(35,209,139,.1);border:1px solid rgba(35,209,139,.35);color:var(--up)}
  .alert.plunge{background:rgba(255,93,108,.1);border:1px solid rgba(255,93,108,.35);color:var(--down)}
  .alert.volume{background:rgba(70,177,255,.1);border:1px solid rgba(70,177,255,.35);color:var(--accent)}
  .alert.none{color:var(--dimmer);font-family:var(--jp)}
  .wrap{padding:14px 18px 60px}
  table{width:100%;border-collapse:collapse;font-family:var(--mono)}
  thead th{text-align:right;font-size:10px;color:var(--dim);font-weight:500;letter-spacing:.5px;padding:8px 10px;border-bottom:1px solid var(--line);cursor:pointer;user-select:none}
  thead th:first-child,thead th:nth-child(2){text-align:left} thead th:hover{color:var(--txt)}
  tbody td{padding:9px 10px;text-align:right;border-bottom:1px solid #131c28}
  tbody td:first-child,tbody td:nth-child(2){text-align:left}
  tbody tr{cursor:pointer;transition:background .12s} tbody tr:hover{background:var(--panel2)}
  .code{color:var(--accent);font-weight:700} .name{font-family:var(--jp);color:var(--txt);font-weight:500}
  .sub{font-family:var(--jp);font-size:10px;color:var(--dim);display:block}
  .up{color:var(--up)}.down{color:var(--down)} .na{color:var(--dimmer)}
  .tag{font-family:var(--jp);display:inline-block;padding:2px 7px;border-radius:4px;font-size:10px;font-weight:500;margin:1px;background:var(--panel2);border:1px solid var(--line);color:var(--dim)}
  .tag.ai{color:#7ee787;border-color:rgba(126,231,135,.3)} .tag.car{color:#79c0ff;border-color:rgba(121,192,255,.3)} .tag.pow{color:#ffa657;border-color:rgba(255,166,87,.3)}
  .ipo{background:linear-gradient(90deg,var(--ipo),#a36fd6);color:#1a0f2e;font-family:var(--mono);font-weight:800;font-size:9px;padding:2px 6px;border-radius:3px;letter-spacing:.5px;margin-left:6px}
  .overlay{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:40;opacity:0;pointer-events:none;transition:.2s}
  .overlay.on{opacity:1;pointer-events:auto}
  .drawer{position:fixed;top:0;right:0;height:100%;width:min(560px,94vw);background:var(--panel);border-left:1px solid var(--line);z-index:50;transform:translateX(100%);transition:.28s cubic-bezier(.4,0,.2,1);overflow-y:auto}
  .drawer.on{transform:translateX(0)}
  .dhead{padding:18px;border-bottom:1px solid var(--line);position:sticky;top:0;background:var(--panel);z-index:2}
  .dhead .x{position:absolute;top:16px;right:16px;color:var(--dim);cursor:pointer;font-size:22px}
  .dprice{font-family:var(--mono);font-size:32px;font-weight:800;margin-top:6px}
  .dmeta{font-family:var(--mono);font-size:10px;color:var(--dim);margin-top:8px;display:flex;gap:6px;align-items:center;flex-wrap:wrap}
  .dbody{padding:18px} .sec{margin-bottom:22px}
  .sec h4{font-family:var(--mono);font-size:11px;color:var(--dim);letter-spacing:1.5px;margin-bottom:10px;padding-bottom:6px;border-bottom:1px solid var(--line)}
  .grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
  .metric{background:var(--panel2);border:1px solid var(--line);border-radius:6px;padding:10px 12px}
  .metric .k{font-size:10px;color:var(--dim)} .metric .v{font-family:var(--mono);font-size:16px;font-weight:700;margin-top:3px}
  .chart{height:120px;width:100%} .empty{color:var(--dimmer);font-size:11px;padding:12px;text-align:center}
  .news a,.disc a{display:block;padding:9px 10px;border-radius:6px;text-decoration:none;color:var(--txt);font-family:var(--jp);font-size:12px;border:1px solid transparent;transition:.12s;line-height:1.4}
  .news a:hover,.disc a:hover{background:var(--panel2);border-color:var(--line)}
  .news .t,.disc .t{font-family:var(--mono);font-size:9px;color:var(--dim);margin-right:8px}
  .src{font-family:var(--mono);font-size:9px;color:var(--accent);border:1px solid var(--line);padding:1px 5px;border-radius:3px;margin-left:6px}
  footer{position:fixed;bottom:0;left:0;right:0;background:#080b10;border-top:1px solid var(--line);padding:7px 18px;font-size:10px;color:var(--dimmer);font-family:var(--mono);text-align:center;z-index:35;line-height:1.5}
  footer b{color:var(--down)}
  .banner{background:rgba(255,180,84,.08);border-bottom:1px solid rgba(255,180,84,.25);color:var(--warn);font-family:var(--mono);font-size:11px;padding:6px 18px;text-align:center}
  @media(max-width:680px){.stat:nth-child(2){display:none}.hideMob{display:none}.dprice{font-size:26px}}
</style>
</head>
<body>
<div id="root"></div>
<script crossorigin src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>
<script crossorigin src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>
<script crossorigin src="https://cdnjs.cloudflare.com/ajax/libs/babel-standalone/7.23.2/babel.min.js"></script>
<script type="text/babel">
const {useState,useEffect,useRef,useCallback}=React;
const API=(localStorage.getItem('SEMICON_API')||'http://localhost:8000');  // バックエンドURL
const THEME_LBL={ai:'生成AI',car:'車載',pow:'パワー半導体'};
const CATS=['all','ipo','製造装置','材料','設計','検査','パワー半導体','後工程'];
const CAT_LBL={all:'全カテゴリ',ipo:'IPO のみ'};
const POLL_MS=30000;  // 表示ポーリング間隔(株価キャッシュTTL=60sに合わせ30s)

function fmt(n){return n==null?'—':Number(n).toLocaleString('ja-JP');}
function tstr(iso){if(!iso)return'--:--:--';const d=new Date(iso);return d.toLocaleTimeString('ja-JP',{hour12:false});}

function Spark({pts,cls}){
  if(!pts||pts.length<2)return <div className="empty">チャートデータなし</div>;
  const w=500,h=120,pad=8,min=Math.min(...pts),max=Math.max(...pts);
  const col=cls==='up'?'#23d18b':'#ff5d6c';
  const x=i=>pad+i*(w-2*pad)/(pts.length-1), y=v=>h-pad-(v-min)/((max-min)||1)*(h-2*pad);
  const dp=pts.map((v,i)=>`${i?'L':'M'}${x(i).toFixed(1)} ${y(v).toFixed(1)}`).join(' ');
  const area=dp+` L${x(pts.length-1)} ${h} L${x(0)} ${h} Z`;
  return <svg className="chart" viewBox={`0 0 ${w} ${h}`} preserveAspectRatio="none">
    <defs><linearGradient id="g" x1="0" x2="0" y1="0" y2="1"><stop offset="0" stopColor={col} stopOpacity=".25"/><stop offset="1" stopColor={col} stopOpacity="0"/></linearGradient></defs>
    <path d={area} fill="url(#g)"/><path d={dp} fill="none" stroke={col} strokeWidth="1.6"/></svg>;
}

function Detail({code,onClose}){
  const [d,setD]=useState(null);
  useEffect(()=>{if(!code)return;setD(null);
    fetch(`${API}/api/stocks/${code}`).then(r=>r.json()).then(setD).catch(()=>setD({error:true}));
  },[code]);
  if(!code)return null;
  const cls=d&&d.change_pct>=0?'up':'down', sign=d&&d.change_pct>=0?'+':'';
  return <>
    <div className={"overlay on"} onClick={onClose}/>
    <div className={"drawer on"}>
      {!d? <div className="dbody"><div className="empty">読み込み中…</div></div> :
       d.error? <div className="dbody"><div className="empty">取得に失敗しました</div></div> :
      <>
       <div className="dhead">
        <span className="x" onClick={onClose}>✕</span>
        <div><span className="code mono" style={{fontSize:13}}>{d.code}</span> {d.ipo&&<span className="ipo">NEW IPO</span>}</div>
        <div className="name" style={{fontSize:17,fontWeight:700,marginTop:2}}>{d.name}</div>
        <div className={"dprice "+cls}>{d.price?`¥${fmt(d.price)}`:'—'} <span style={{fontSize:15}}>{d.change_pct!=null?`${sign}${d.change_pct}%`:''}</span></div>
        <div className="dmeta"><span className="pulse" style={{background:'var(--warn)'}}></span>15分遅延 · 取得 {tstr(d.fetched_at)} · {d.sub}
          {d.themes.map(t=><span key={t} className={"tag "+t}>{THEME_LBL[t]}</span>)}</div>
       </div>
       <div className="dbody">
        <div className="sec"><h4>PRICE CHART · 直近30日(日足)</h4><Spark pts={d.history} cls={cls}/></div>
        <div className="sec"><h4>METRICS · 指標</h4><div className="grid">
          <div className="metric"><div className="k">出来高</div><div className="v">{d.volume?(d.volume/1e6).toFixed(1)+'M':'—'}</div></div>
          <div className="metric"><div className="k">PER</div><div className="v">{d.per??'—'}</div></div>
          <div className="metric"><div className="k">時価総額</div><div className="v" style={{fontSize:13}}>{d.market_cap?(d.market_cap/1e8).toFixed(0)+'億円':'—'}</div></div>
          <div className="metric"><div className="k">配当利回り</div><div className="v" style={{fontSize:13}}>{d.dividend_yield?d.dividend_yield+'%':'—'}</div></div>
        </div></div>
        <div className="sec disc"><h4>DISCLOSURE · 開示(EDINET)</h4>
          {d.disclosures&&d.disclosures.length? d.disclosures.map((x,i)=>
            <a key={i} href={x.doc_id?`https://disclosure2.edinet-fsa.go.jp/WEEK0040.aspx?bXk0%2b...=${x.doc_id}`:'#'} target="_blank" rel="noopener">
              <span className="t">{x.date}</span>{x.doc_type||'開示書類'}<span className="src">EDINET</span></a>)
          : <div className="empty">直近の開示なし（または取得不可）</div>}</div>
        <div className="sec news"><h4>NEWS · 見出し(RSS)</h4>
          {d.news&&d.news.length? d.news.map((x,i)=>
            <a key={i} href={x.link} target="_blank" rel="noopener"><span className="t">{x.source}</span>{x.title}<span className="src">RSS</span></a>)
          : <div className="empty">ニュースなし（または取得不可）</div>}</div>
        <p style={{fontSize:10,color:'var(--dimmer)',fontFamily:'var(--mono)',lineHeight:1.6}}>
          ※ 参考情報です。売買を推奨するものではありません。株価は約15分遅延データ。</p>
       </div>
      </>}
    </div>
  </>;
}

function App(){
  const [stocks,setStocks]=useState([]);
  const [meta,setMeta]=useState({});
  const [alerts,setAlerts]=useState([]);
  const [cat,setCat]=useState('all');
  const [q,setQ]=useState('');
  const [sort,setSort]=useState({k:'volume',d:-1});
  const [sel,setSel]=useState(null);
  const [conn,setConn]=useState('connecting');
  const [now,setNow]=useState(Date.now());
  const lastUpdRef=useRef(null);

  const load=useCallback(()=>{
    Promise.all([
      fetch(`${API}/api/stocks`).then(r=>r.json()),
      fetch(`${API}/api/alerts`).then(r=>r.json()),
      fetch(`${API}/api/meta`).then(r=>r.json()),
    ]).then(([s,a,m])=>{
      setStocks(s.stocks||[]); setAlerts(a.alerts||[]); setMeta(m);
      lastUpdRef.current=s.last_update||m.last_update||new Date().toISOString();
      setConn('ok');
    }).catch(()=>setConn('ng'));
  },[]);

  useEffect(()=>{load();const p=setInterval(load,POLL_MS);return()=>clearInterval(p);},[load]);
  useEffect(()=>{const t=setInterval(()=>setNow(Date.now()),1000);return()=>clearInterval(t);},[]);

  const elapsed=lastUpdRef.current?Math.floor((now-new Date(lastUpdRef.current).getTime())/1000):0;

  let list=stocks.filter(s=>{
    if(cat==='ipo'&&!s.ipo)return false;
    if(cat!=='all'&&cat!=='ipo'&&s.sub!==cat)return false;
    if(q){const x=q.toLowerCase();if(!s.code.toLowerCase().includes(x)&&!s.name.toLowerCase().includes(x))return false;}
    return true;
  });
  list.sort((a,b)=>{const k=sort.k;
    if(k==='name')return sort.d*String(a.name).localeCompare(b.name,'ja');
    if(k==='code')return sort.d*String(a.code).localeCompare(b.code);
    return sort.d*((a[k]||0)-(b[k]||0));});
  list.sort((a,b)=>(a.ipo?0:1)-(b.ipo?0:1));

  const setS=k=>setSort(s=>s.k===k?{k,d:-s.d}:{k,d:-1});

  return <>
    <header>
      <div className="brand">SEMICON<b>·</b>SCOPE<small>日本株 半導体銘柄スコープ</small></div>
      <div className="clock">
        <span className={"conn "+(conn==='ok'?'ok':'ng')}>{conn==='ok'?'● LIVE':conn==='connecting'?'○ 接続中':'× API未接続'}</span>
        <div className="stat">現在時刻(JST)<b className="mono">{new Date(now).toLocaleTimeString('ja-JP',{hour12:false})}</b></div>
        <div className="stat">最終更新<b className="mono">{tstr(lastUpdRef.current)}</b></div>
        <div className="delaybadge"><span className="pulse"></span>{meta.delay_label||'15分遅延'}
          <span style={{color:'var(--dim)'}}>|</span> 経過 <span className="counter mono">{elapsed}</span>秒</div>
      </div>
    </header>

    {conn==='ng'&&<div className="banner">バックエンドAPI ({API}) に接続できません。backend を起動してください（uvicorn main:app --port 8000）。接続先は localStorage.SEMICON_API で変更可。</div>}

    <div className="controls">
      <div className="search"><input value={q} onChange={e=>setQ(e.target.value)} placeholder="銘柄コード / 社名で検索 ..."/></div>
      <div className="chips">{CATS.map(c=>
        <span key={c} className={"chip"+(cat===c?' on':'')} onClick={()=>setCat(c)}>{CAT_LBL[c]||c}</span>)}</div>
    </div>

    <div className="alerts">
      <span className="lbl">⚡ ALERTS</span>
      {alerts.length? alerts.map((a,i)=><span key={i} className={"alert "+a.type}>{a.label}</span>)
       : <span className="alert none">現在アラートはありません</span>}
    </div>

    <div className="wrap">
      <table>
        <thead><tr>
          <th onClick={()=>setS('code')}>コード</th>
          <th onClick={()=>setS('name')}>銘柄 / サブカテゴリ</th>
          <th onClick={()=>setS('price')}>株価</th>
          <th onClick={()=>setS('change_pct')}>前日比</th>
          <th className="hideMob" onClick={()=>setS('volume')}>出来高</th>
          <th className="hideMob" onClick={()=>setS('per')}>PER</th>
          <th className="hideMob">テーマ</th>
        </tr></thead>
        <tbody>{list.map(s=>{
          const cls=s.change_pct>=0?'up':'down', sign=s.change_pct>=0?'+':'';
          return <tr key={s.code} onClick={()=>setSel(s.code)}>
            <td className="code">{s.code}</td>
            <td><span className="name">{s.name}</span>{s.ipo&&<span className="ipo">NEW IPO</span>}<span className="sub">{s.sub}</span></td>
            <td className="mono">{s.price?fmt(s.price):<span className="na">—</span>}</td>
            <td className={"mono "+(s.change_pct==null?'na':cls)}>{s.change_pct!=null?`${sign}${s.change_pct}%`:'—'}</td>
            <td className="mono hideMob" style={{color:s.volume>1e7?'var(--accent)':'var(--txt)'}}>{s.volume?(s.volume/1e6).toFixed(1)+'M':'—'}</td>
            <td className="mono hideMob">{s.per??'—'}</td>
            <td className="hideMob">{s.themes.length? s.themes.map(t=><span key={t} className={"tag "+t}>{THEME_LBL[t]}</span>):<span className="tag">—</span>}</td>
          </tr>;})}
        </tbody>
      </table>
      {!list.length&&<div className="empty">該当銘柄がありません{conn==='ok'?'':'（API接続待ち）'}</div>}
    </div>

    <Detail code={sel} onClose={()=>setSel(null)}/>

    <footer><b>本アプリは情報収集・参考目的であり、投資判断・売買推奨を行うものではありません。</b>
      株価は無料ソース由来の遅延データ（約15分遅延・yfinance）。出典: 株価=yfinance / 開示=EDINET / ニュース=RSS。</footer>
  </>;
}
ReactDOM.createRoot(document.getElementById('root')).render(<App/>);
</script>
</body>
</html>
